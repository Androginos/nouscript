NOUS_API_KEY=your_api_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
GROQ_API_KEY=your_groq_api_key_here
# RapidAPI: proxy secret (RapidAPI panelinden alınır). Boş bırakılırsa x-rapidapi-key varlığı yeterli.
# RAPIDAPI_PROXY_SECRET=
# RapidAPI indirme servisleri (yedekli, virgülle ayırın). Social Download All In One formatı.
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOSTS=social-download-all-in-one.p.rapidapi.com,host2.p.rapidapi.com
# veya tek host: RAPIDAPI_YOUTUBE_HOST=social-download-all-in-one.p.rapidapi.com
# Sadece RapidAPI kullanılır. Invidious yedek değildir.
# API Key Name: dissident_plurality
# Groq API Key: https://console.groq.com/keys (free)
