NOUS_API_KEY=your_api_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
GROQ_API_KEY=your_groq_api_key_here
# RapidAPI: proxy secret (RapidAPI panelinden alınır). Boş bırakılırsa x-rapidapi-key varlığı yeterli.
# RAPIDAPI_PROXY_SECRET=
# RapidAPI indirme servisleri (virgülle ayırın). Örnek: sadece bu iki abonelik varsa:
# - Youtube Audio Mp3 Downloader (YouTube M4A/MP3)
# - Social Download All In One (YouTube, TikTok, X vb. autolink)
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOSTS=youtube-mp3-audio-video-downloader.p.rapidapi.com,social-download-all-in-one.p.rapidapi.com
# API Key Name: dissident_plurality
# Groq API Key: https://console.groq.com/keys (free)

# Telegram video summary bot (@NouScript_Sumbot) — telegram_bot.py bu token'ı kullanır.
# Hermes sohbet botu (@Nouscript_bot) ayrı; onun token'ı ~/.hermes/.env'de, burada değil.
TELEGRAM_BOT_TOKEN=your_NouScript_Sumbot_token_from_botfather
NOUSCRIPT_API_BASE=https://nouscript.com
# RAPIDAPI_KEY=... (zaten yukarıda varsa aynı key bot'ta /api/v1/summarize için kullanılır)
